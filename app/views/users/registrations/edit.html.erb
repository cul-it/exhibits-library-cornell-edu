<div class="container">
  <h2>Manage Account</h2>
  <h3>Delete account</h3>
  <p>Deleting your account on Cornell University Library's Online Exhibitions is irreversible.</p>
  <% user_exhibit_roles = current_user.exhibit_roles %>
  <% if user_exhibit_roles.any? %>
    <p>If you delete your account, you will no longer have the following exhibit permissions:</p>
    <ul class="list-group">
      <% user_exhibit_roles.each do |role| %>
        <li class="list-group-item"><%= role.resource.title %> <strong>(<%= role.role %>)</strong></li>
      <% end %>
    </ul>
  <% end %>
  <div class="mt-3">
    <%= button_to "Delete my account", destroy_user_registration_path, data: { confirm: "Are you sure?", turbo_confirm: "Are you sure?" }, method: :delete, class: "btn btn-danger" %>
  </div>
</div>
